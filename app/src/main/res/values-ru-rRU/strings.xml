    <!-- NFC Glyph -->
    <string name="nfc_glyph_title">NFC Glyph</string>
    <string name="nfc_glyph_description">Анимация Glyph при NFC событии</string>
    <string name="nfc_glyph_toast">Сначала включите Glyph-сервис</string>
    <string name="nfc_glyph_how_it_works_title">Как это работает:</string>
    <string name="nfc_glyph_how_it_works_description">• Срабатывает при оплате (Google Pay и др.)\n• Срабатывает при сканировании NFC-метки\n• Воспроизводит выбранную анимацию Glyph\n• Учитывает режим «Тишина», если включён</string>
    <string name="nfc_glyph_configure_title">Настройка</string>
    <string name="nfc_glyph_configure_subtitle">Настройте анимацию для NFC</string>
    <string name="nfc_glyph_button_test">Протестировать</string>
    <string name="nfc_glyph_animation_title">Анимация</string>
    <string name="nfc_glyph_animation_test">Тест: </string>
    <string name="nfc_glyph_duration_title">Длительность отображения</string>
    <string name="nfc_glyph_duration_min">1с</string>
    <string name="nfc_glyph_duration_max">10с</string>
    <string name="nfc_glyph_duration_description">Как долго воспроизводится анимация после NFC-события</string>
    <string name="nfc_glyph_note_title">Примечание</string>
    <string name="nfc_glyph_note_description">• NFC должен быть включён в настройках системы\n• Работает с Google Pay, сканированием меток и др.\n• Обнаружение платежей HCE — автоматическое\n• Обнаружение меток требует, чтобы приложение было на переднем плане</string>
    <string name="nfc_glyph_button_enable">Включить</string>

